# --- Veritabani ---
# Gelistirme (varsayilan): SQLite
DATABASE_URL=sqlite+aiosqlite:///./ilkonbir.db
# Docker/prod: PostgreSQL
# DATABASE_URL=postgresql+asyncpg://ilkonbir:ilkonbir@localhost:5432/ilkonbir

# --- API-Football (api-football.com) ---
# Anahtar yoksa senkronizasyon atlanir; uygulama seed verisiyle calisir.
API_FOOTBALL_KEY=
API_FOOTBALL_USE_RAPIDAPI=false
API_FOOTBALL_LEAGUES=203,39,140,78,135,61
API_FOOTBALL_SEASON=2025

# --- transfermarkt-api (felipeall/transfermarkt-api, docker-compose ile) ---
TRANSFERMARKT_API_URL=http://localhost:8001

# --- Zamanlanmis senkronizasyon ---
ENABLE_SCHEDULER=false
SYNC_CLUBS_CRON_HOUR=3
SYNC_MARKET_VALUES_CRON_HOUR=4

# --- /admin/sync korumasi (bos birakilirsa token istenmez) ---
ADMIN_TOKEN=

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
